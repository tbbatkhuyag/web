            <option value="2">Агуулга</option>
            <option value="3">Холбоос</option>
            <option value="4">Жагсаалт</option>
        </select>
        <span asp-validation-for="Txttype" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Vis" class="control-label"></label>
        <select id="Vis" asp-for="Vis" name="Txttype" class="form-control">
            <option value="1">НУУХ</option>
            <option value="2">НЭЭХ</option>
        </select>
        <span asp-validation-for="Vis" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="TxtOrd" class="control-label"></label>
        <input asp-for="TxtOrd" class="form-control" />
        <span asp-validation-for="TxtOrd" class="text-danger"></span>
    </div>

