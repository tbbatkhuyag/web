@model edu.Models.NewsList
@inject edu_portal_dbContext Contex
@{
    ViewData["Title"] = "Delete";
    Layout = "~/Views/Shared/_Layoutadmin.cshtml";
    var txtname = Contex.NewsCats.SingleOrDefault(vs => vs.Id == Int32.Parse(ViewData["newsid"].ToString())).Txtname;
}


<h1>@txtname</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>NewsList</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Txtname)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Txtname)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Txtmore)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Txtmore)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Txtcontent)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Txtcontent)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Txtdate)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Txtdate)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Txtdatetime)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Txtdatetime)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Cat)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Cat.Id)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
     
    </form>
</div>
