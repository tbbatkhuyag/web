@using System.Security.Claims
@model edu.Models.Lesson

@{
    ViewData["Title"] = "Edit";
    Layout = "~/Views/Shared/_Layoutteacher.cshtml";
}

<h1>Edit</h1>
@* 
<h4>Хичээлийн нэр: @ViewBag.name</h4> *@
<hr />
<div class="row">
    <div class="col-md-12">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ViewMinut" class="control-label"></label>
                <input asp-for="ViewMinut" class="form-control" />
                <span asp-validation-for="ViewMinut" class="text-danger"></span>
            </div>
            <div class="input-block">
                <label asp-for="Txtmore" class="control-label"></label>
            @*     <input asp-for="Txtmore" class="form-control" /> *@
                @(Html.Kendo().Editor()
                    .Name("Txtmore")
                    .HtmlAttributes(new { style = "width: 100%; height:300px" })
                    .StyleSheets(css => css
                    .Add(Url.Content("~/shared/web/editor/editorStyles.css"))
                    )
                    .Tools(tools => tools
                    .Clear()
                    .Bold().Italic().Underline()
                    .JustifyLeft().JustifyCenter().JustifyRight()
                    .InsertUnorderedList().InsertOrderedList()
                    .Outdent().Indent()
                    .CreateLink().Unlink()
                    .InsertImage()
                    .TableEditing()
                    .FontName()
                    .FontSize()
                    .ForeColor().BackColor()
                    )
                    .ImageBrowser(imageBrowser => imageBrowser
                    .Image("~/shared/UserFiles/images/" + User.FindFirst(ClaimTypes.Name)?.Value + "//{0}")



                    .Read("Read", "ImageBrowser")
                    .Create("Create", "ImageBrowser")
                    .Destroy("Destroy", "ImageBrowser")
                    .Upload("Upload", "ImageBrowser")
                    ).Value(ViewBag.Txtmore)
                    )
                <span asp-validation-for="Txtmore" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Txtcontent" class="control-label"></label>
              @*   <input asp-for="Txtcontent" class="form-control" /> *@
                @(Html.Kendo().Editor()
                    .Name("Txtcontent")
                    .HtmlAttributes(new { style = "width: 100%; height:300px" })
                    .StyleSheets(css => css
                    .Add(Url.Content("~/shared/web/editor/editorStyles.css"))
                    )
                    .Tools(tools => tools
                    .Clear()
                    .Bold().Italic().Underline()
                    .JustifyLeft().JustifyCenter().JustifyRight()
                    .InsertUnorderedList().InsertOrderedList()
                    .Outdent().Indent()
                    .CreateLink().Unlink()
                    .InsertImage()
                    .TableEditing()
                    .FontName()
                    .FontSize()
                    .ForeColor().BackColor()
                    )
                    .ImageBrowser(imageBrowser => imageBrowser
                    .Image("~/shared/UserFiles/images/" + User.FindFirst(ClaimTypes.Name)?.Value + "//{0}")


                    .Read("Read", "ImageBrowser")
                    .Create("Create", "ImageBrowser")
                    .Destroy("Destroy", "ImageBrowser")
                    .Upload("Upload", "ImageBrowser")
                    ).Value(ViewBag.Txtcontent)
                    )
                <span asp-validation-for="Txtcontent" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Txtwork" class="control-label"></label>
                @* <input asp-for="Txtcontent" class="form-control" /> *@
                @(Html.Kendo().Editor()
                    .Name("Txtwork")
                    .HtmlAttributes(new { style = "width: 100%; height:300px" })
                    .StyleSheets(css => css
                    .Add(Url.Content("~/shared/web/editor/editorStyles.css"))
                    )
                    .Tools(tools => tools
                    .Clear()
                    .Bold().Italic().Underline()
                    .JustifyLeft().JustifyCenter().JustifyRight()
                    .InsertUnorderedList().InsertOrderedList()
                    .Outdent().Indent()
                    .CreateLink().Unlink()
                    .InsertImage()
                    .TableEditing()
                    .FontName()
                    .FontSize()
                    .ForeColor().BackColor()
                    )
                    .ImageBrowser(imageBrowser => imageBrowser
                    .Image("~/shared/UserFiles/images/" + User.FindFirst(ClaimTypes.Name)?.Value + "//{0}")
                  

                    .Read("Read", "ImageBrowser")
                    .Create("Create", "ImageBrowser")
                    .Destroy("Destroy", "ImageBrowser")
                    .Upload("Upload", "ImageBrowser")
                    )
                    )

                <span asp-validation-for="Txtwork" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Txtvoice" class="control-label"></label>
                <input asp-for="Txtvoice" hidden class="form-control" />
                @(Html.Kendo().Upload()
                    .Name("files1")
                    .Async(a => a
                    .Save("Validation_Save", "Upload")
                    .Remove("Validation_Remove", "Upload")
                    .SaveField("files")

                    )
                    .Validation(validation => validation.AllowedExtensions(new string[] { ".docx" }))
                    .Multiple(false)
                    .TemplateId("Txtvoice")
                    .Events(events => events.Select("onSelect1"))
                    )
                <span asp-validation-for="Txtvoice" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Txtvideo" class="control-label"></label>
                <input asp-for="Txtvideo" hidden class="form-control" />
                @(Html.Kendo().Upload()
                    .Name("files")
                    .Async(a => a
                    .Save("Validation_Save", "Upload")
                    .Remove("Validation_Remove", "Upload")
                    .SaveField("files")

                    )
                    .Validation(validation => validation.AllowedExtensions(new string[] { ".docx" }))
                    .Multiple(false)
                    .TemplateId("Txtvideo")
                    .Events(events => events.Select("onSelect"))
                    )
                <span asp-validation-for="Txtvideo" class="text-danger"></span>
            </div>

            <script type="text/javascript">
                function onSelect(e) {
                    var fileName = e.files[0].name;  // Get the name of the first file
                    console.log("Selected file name: " + fileName);

                    // Display the file name in an HTML element (optional)
                    document.getElementById("Txtvideo").setAttribute('value', fileName);
                    //  $("#Txtvideo").text(fileName);
                }
                function onSelect1(e) {
                    var fileName = e.files[0].name;  // Get the name of the first file
                    console.log("Selected file name: " + fileName);

                    // Display the file name in an HTML element (optional)
                    document.getElementById("Txtvoice").setAttribute('value', fileName);
                    //  $("#Txtvideo").text(fileName);
                }
            </script>
           @*  <div class="form-group">
                <label asp-for="GId" class="control-label"></label>
                <input asp-for="GId" class="form-control" />
                <span asp-validation-for="GId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="TeacherId" class="control-label"></label>
                <input asp-for="TeacherId" class="form-control" />
                <span asp-validation-for="TeacherId" class="text-danger"></span>
            </div> *@
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
